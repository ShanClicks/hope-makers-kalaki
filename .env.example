# Resend (https://resend.com) — powers the /contact page email delivery.
# Get an API key from https://resend.com/api-keys after signing up.
RESEND_API_KEY=

# Optional overrides. Defaults live in src/app/api/contact/route.ts.
# CONTACT_TO_EMAIL=hopemakerskalaki@gmail.com
# CONTACT_FROM_EMAIL=Hope Makers Kalaki <onboarding@resend.dev>

# MarzPay (https://wallet.wearemarz.com) — powers Mobile Money donations on the Donate page.
# Get your API key + secret from the MarzPay dashboard after signing up.
# Sandbox mode is automatic on a new business account, so these can be test credentials.
MARZPAY_API_KEY=
MARZPAY_API_SECRET=

# Local SQLite database for the /admin panel. For production, point this at a hosted
# Postgres/MySQL instance instead (e.g. Vercel Postgres, Supabase, Neon, PlanetScale)
# and change the "provider" in prisma/schema.prisma to match.
DATABASE_URL="file:./dev.db"

# /admin password gate. ADMIN_PASSWORD is the shared login password for the admin panel.
# ADMIN_SESSION_SECRET signs the login session cookie — generate a random string for it,
# e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"`.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
